# ── Node / Next.js ────────────────────────────────────────────────────────────
frontend/node_modules
frontend/.next/
frontend/out/
frontend/build
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Yarn / pnpm / npm logs
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Python (legacy CLI prototype) ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg
*.egg-info/
dist/
.eggs/
.venv/
venv/
env/
.env/

# ── Environment & Secrets (NEVER commit these) ────────────────────────────────
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Editors & IDEs ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

